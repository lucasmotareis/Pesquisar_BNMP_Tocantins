# Exemplo para VPS/Coolify usando o dominio publico do painel.
# Troque todos os valores "gere-..." por segredos longos antes de subir.

APP_PORT=8765
BNMP_DATA_PATH=/opt/bnmp-data
BNMP_DATA_FILE=/app/data/mandados_processados.json
BNMP_COOKIES_FILE=/app/data/bnmp_cookies.json

ADMIN_PASSWORD=gere-uma-senha-administrativa-forte
APP_BASIC_AUTH_USER=bnmp
APP_BASIC_AUTH_PASSWORD=gere-uma-senha-forte-para-abrir-o-painel

BNMP_BROWSER_EXPORT_TOKEN=gere-um-token-interno-longo
BNMP_VNC_PASSWORD=gere-uma-senha-forte-para-o-novnc
BNMP_BROWSER_PORT=6080
BNMP_BROWSER_COOKIE_WAIT_SECONDS=12
BNMP_CAPTURED_SESSION_MAX_AGE_SECONDS=600
BNMP_REMOTE_BROWSER_URL=https://bnmp.pmto8bpm.com.br/vnc.html?autoconnect=1&resize=remote
BNMP_COOKIE_TTL_SECONDS=240
BNMP_ENABLE_HSTS=true
